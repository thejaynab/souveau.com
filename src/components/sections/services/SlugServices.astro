---
import Button from '@/components/ui/buttons/Button.astro';
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';

interface Props {
  service: CollectionEntry<'services'>;
}

const { service } = Astro.props;
---

{/* Hero Section */}
<section class="relative h-[60vh] w-full overflow-hidden">
  <div class="absolute inset-0">
    <img src={service.data.image} alt={service.data.title} class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-black/40"></div>
    <!-- Gradient-->
    <div
      class="absolute inset-x-0 bottom-0 h-[60%] bg-black/40 mask-[linear-gradient(to_top,black,transparent)] backdrop-blur-md"
    >
    </div>
  </div>

  <div class="relative z-10 flex h-full items-end justify-center pb-10 md:pb-20">
    <div class="flex flex-col items-center gap-4 px-4 text-center md:gap-8">
      <h1 class="font-boldonse text-primary text-3xl leading-tight uppercase md:text-5xl lg:text-8xl">
        {service.data.title}
      </h1>
      <p class="text-primary text- max-w-2xl md:text-2xl">
        {service.data.description}
      </p>
    </div>
  </div>
</section>

{/* Content Section */}
<section class="container mx-auto px-4 py-24">
  <div class="mx-auto max-w-5xl pb-6 md:pb-10">
    <Button href="/#services-section" variant="outline" effect="shadowOffsetDark">
      <Icon name="arrow" class="h-6 w-6 rotate-180" />Back to Home
    </Button>
  </div>
  <div class="content-style mx-auto max-w-5xl">
    <slot />
  </div>
</section>
