---
import { t } from '@/lib/utils';
---

<section class="fixed top-0 left-0 z-0 h-dvh w-full overflow-hidden" style="background-color: rgb(10, 10, 10);">
  <!-- video removed -->

  <div id="hero-content" class="relative z-10 flex h-full items-center justify-center p-4 lg:p-8">
    <div class="w-full overflow-hidden text-center">
      <h1 id="hero-title" class="text-primary font-boldonse text-4xl leading-normal uppercase lg:text-6xl xl:text-8xl">
        {t('index.h1')}
      </h1>
    </div>
  </div>
</section>

<!-- Spacer so that the content starts after the hero -->
<div class="h-dvh"></div>

<script>
  import gsap from 'gsap';

  // No video — emit ready event immediately
  window.dispatchEvent(new Event('heroVideoReady'));

  // Hero animation setup
  const heroTitle = document.getElementById('hero-title');
  const heroContent = document.getElementById('hero-content');

  if (heroTitle && heroContent) {
    // Set initial state - hidden
    gsap.set(heroTitle, {
      y: 100,
      opacity: 0,
    });

    // Listen for loading complete event
    window.addEventListener(
      'loadingComplete',
      () => {
        // Animate hero title entrance
        gsap.to(heroTitle, {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: 'power3.out',
          delay: 0.2,
        });
      },
      { once: true },
    );
  }
</script>
