---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { teamMembers } from '@/config/team.data';
import MarqueeText from '@/components/common/MarqueeText.astro';
import { t } from '@/lib/utils';
import Button from '@/components/ui/buttons/Button.astro';
---

<section id="team-section" class="px-4 py-24 lg:py-32">
  <div class="container mx-auto space-y-10 md:space-y-16">
    <!-- Header -->
    <div class="team-header space-y-6 text-center">
      <div class="team-marquee mx-auto w-fit">
        <MarqueeText text={t('studio.team.marqueetext')} />
      </div>
      <h2 class="font-boldonse team-title text-4xl leading-normal uppercase md:text-6xl lg:text-7xl">
        {t('studio.team.title')}
      </h2>
    </div>

    <!-- Cards Team -->
    <div class="team-grid mx-auto grid max-w-7xl grid-cols-1 gap-6 lg:grid-cols-2">
      {
        teamMembers.map((member) => (
          <div class="team-card bg-muted-light/30 border-muted flex flex-col gap-6 rounded-2xl border p-4 sm:flex-row">
            <div class="relative aspect-square w-full shrink-0 overflow-hidden rounded-2xl sm:w-1/3 md:w-2/5 lg:w-1/3 xl:w-2/5">
              {typeof member.image === 'string' ? (
                // External URL
                <Image
                  src={member.image}
                  alt={member.name}
                  class="h-full w-full object-cover object-[70%_center] opacity-90"
                  width={900}
                  height={900}
                  quality={90}
                  loading="lazy"
                />
              ) : (
                // ImageMetadata (imported from /src/assets)
                <Image
                  src={member.image}
                  alt={member.name}
                  class="h-full w-full object-cover object-[70%_center] opacity-90"
                  quality={90}
                  loading="lazy"
                  inferSize
                />
              )}
            </div>
            <div class="flex flex-col justify-center py-2">
              <div class="space-y-1">
                <h3 class="font-boldonse text-3xl leading-normal uppercase md:text-4xl">{member.name}</h3>
                <p class="text-muted-foreground text-sm font-medium">{member.role}</p>
              </div>

              <div class="border-muted-light/60 my-6 border-t" />

              <div class="flex gap-3">
                {member.socials.map((social) => (
                  <Button href={social.url} target="_blank" rel="noopener noreferrer" size="icon" effect="bgFillV">
                    <Icon name={`socials-icons/${social.icon}`} class="h-12 w-12" />
                  </Button>
                ))}
              </div>

              <p class="text-muted-foreground mt-6 text-base leading-relaxed">{member.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initTeamAnimations() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    gsap.from('#team-section .team-marquee', {
      opacity: 0,
      ...(prefersReducedMotion ? {} : { y: -30 }),
      duration: 0.6,
      scrollTrigger: {
        trigger: '#team-section',
        start: 'top 75%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.from('#team-section .team-title', {
      opacity: 0,
      ...(prefersReducedMotion ? {} : { y: 30 }),
      duration: 0.6,
      scrollTrigger: {
        trigger: '#team-section .team-title',
        start: 'top 80%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.from('#team-section .team-card', {
      opacity: 0,
      ...(prefersReducedMotion ? {} : { y: 40 }),
      duration: 0.6,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#team-section .team-grid',
        start: 'top 80%',
        toggleActions: 'play none none reverse',
      },
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTeamAnimations);
  } else {
    initTeamAnimations();
  }

  document.addEventListener('astro:page-load', initTeamAnimations);
</script>
