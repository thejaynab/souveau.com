---
import type { FAQ } from '@/config/faq.data';
import { Icon } from 'astro-icon/components';

interface Props {
  faq: FAQ;
  index: number;
}

const { faq, index } = Astro.props;
---

<div class="accordion-item group bg-secondary rounded-2xl border p-1 transition-all duration-300 hover:shadow-2xl">
  <button
    type="button"
    class="accordion-trigger group flex w-full cursor-pointer items-center justify-between gap-6 p-6 text-left md:p-8"
    aria-expanded="false"
    aria-controls={`faq-content-${index}`}
  >
    <h3 class="text-primary text-base font-semibold md:text-xl">{faq.question}</h3>
    <div class="pointer-events-none relative flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden">
      <Icon name="plus" class="accordion-icon text-primary h-6 w-6 transition-transform duration-300" />
    </div>
  </button>
  <div
    id={`faq-content-${index}`}
    class="accordion-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out"
  >
    <div class="overflow-hidden">
      <p class="text-muted-light p-6 text-base leading-relaxed md:text-lg">{faq.answer}</p>
    </div>
  </div>
</div>

<script>
  function setupAccordion() {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.accordion-item');
        if (!item) return;

        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        const content = item.querySelector<HTMLElement>('.accordion-content');
        const icon = trigger.querySelector<SVGElement>('.accordion-icon');

        document.querySelectorAll<HTMLButtonElement>('.accordion-trigger').forEach((otherTrigger) => {
          if (otherTrigger !== trigger) {
            const otherItem = otherTrigger.closest('.accordion-item');
            const otherContent = otherItem?.querySelector<HTMLElement>('.accordion-content');
            const otherIcon = otherTrigger.querySelector<SVGElement>('.accordion-icon');

            otherTrigger.setAttribute('aria-expanded', 'false');

            if (otherContent) {
              otherContent.style.gridTemplateRows = '0fr';
            }

            if (otherIcon) {
              otherIcon.style.transform = 'rotate(0deg)';
            }
          }
        });

        trigger.setAttribute('aria-expanded', String(!isExpanded));

        if (content) {
          content.style.gridTemplateRows = isExpanded ? '0fr' : '1fr';
        }

        if (icon) {
          icon.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(45deg)';
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupAccordion);
  } else {
    setupAccordion();
  }

  document.addEventListener('astro:page-load', setupAccordion);
</script>
