---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/buttons/Button.astro';
import { t } from '@/lib/utils';
---

<Layout title={t('meta.404.title')} description={t('meta.404.description')}>
  <section class="bg-body flex min-h-dvh items-center justify-center px-4 py-28 md:py-32">
    <div class="mx-auto max-w-3xl space-y-10 text-center">
      <!-- Large 404 -->
      <h1 class="font-boldonse text-orange text-6xl leading-none md:text-7xl lg:text-9xl">
        {t('404.h1')}
      </h1>

      <!-- Error Message -->
      <div class="space-y-6">
        <h2 class="font-boldonse text-primary text-4xl leading-tight md:text-5xl lg:text-6xl">
          {t('404.h2')}
        </h2>
        <p class="text-muted-light font-inter mx-auto max-w-2xl text-lg md:text-xl">
          {t('404.description')}
        </p>
      </div>

      <!-- Navigation Options -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button variant="secondary" size="md" href="/" class="w-full sm:w-auto">
          {t('404.back.btn')}
        </Button>
        <Button variant="secondary" size="md" href="/contact" class="w-full sm:w-auto">
          {t('404.contact.btn')}
        </Button>
      </div>
    </div>
  </section>
</Layout>
