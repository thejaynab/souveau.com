---
import Layout from '@/layouts/Layout.astro';
import Cta from '@/components/common/Cta.astro';
import HeroStudio from '@/components/sections/studio/HeroStudio.astro';
import OurStory from '@/components/sections/studio/OurStory.astro';
import OurValues from '@/components/sections/studio/OurValues.astro';
import WorkProcess from '@/components/sections/studio/WorkProcess.astro';
import Team from '@/components/sections/studio/Team.astro';
import { t } from '@/lib/utils';
---

<Layout title={t('meta.studio.title')} description={t('meta.studio.description')} keywords={t('meta.studio.keywords')}>
  <HeroStudio />
  <OurStory />
  <OurValues />
  <WorkProcess />
  <Team />
  <Cta />
</Layout>
